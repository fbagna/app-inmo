<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Whole_Bathrooms</fullName>
    <active>true</active>
    <errorConditionFormula>FLOOR(Bathrooms__c) &lt;&gt; Bathrooms__c</errorConditionFormula>
    <errorDisplayField>Bathrooms__c</errorDisplayField>
    <errorMessage>The number of bathrooms must be a whole number (no decimals).</errorMessage>
</ValidationRule>
